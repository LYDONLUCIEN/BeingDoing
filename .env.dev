# ==========================================================
# 开发环境覆盖配置
# 用法: ./start.sh start dev
# 加载顺序: .env (base) → .env.dev (覆盖)
# ==========================================================

APP_ENV=development
DEBUG=True
DEBUG_MODE=True

# 数据库（SQLite 本地开发）
DATABASE_URL=sqlite+aiosqlite:///./app.db

# 前端
FRONTEND_URL=https://career.soulhappylab.com
NEXT_PUBLIC_API_URL=
FRONTEND_MODE=dev

# Admin 调试
ADMIN_DEBUG_POLICY_ENABLED=True
ADMIN_DEBUG_WORKSPACE_ENABLED=True
ADMIN_SANDBOX_ENABLED=True
