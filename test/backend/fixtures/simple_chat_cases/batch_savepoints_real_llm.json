      "seed_fixture": {
        "report_dir": "test/backend/fixtures/simple_chat_reports/mock_values_pending",
        "ttl_minutes": 180
      },
      "phase": "values",
      "thread_id": "t_mock_pending_001",
      "steps": [
        {
          "message": "这个总结不太准确，我先不确认。请你继续问我，帮助你更准确理解。"
