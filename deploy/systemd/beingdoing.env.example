# ===============================
# BeingDoing systemd env example
# Copy to: /etc/beingdoing.env
# ===============================

# App
APP_ENV=production
DEBUG=False
DEBUG_MODE=True
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
SUPER_ADMIN_USER_IDS=
SUPER_ADMIN_EMAILS=q510971228@gmail.com,q510971228@163.com

# Database
DATABASE_URL=sqlite+aiosqlite:///./app.db
ARCHITECTURE_MODE=simple

# Default LLM (current effective provider)
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-d02cb365ca2b4b0db9ce11befe9a77ea
OPENAI_API_KEY=

# Reserved providers (not used by current backend code directly)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Audio
AUDIO_MODE=False
ASR_PROVIDER=openai
OPENAI_WHISPER_API_KEY=
TTS_PROVIDER=openai
OPENAI_TTS_API_KEY=

# SMTP (forgot password email)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=q510971228@163.com
SMTP_PASS=replace-with-163-smtp-auth-code
SMTP_FROM_EMAIL=q510971228@163.com
SMTP_FROM_NAME=BeingDoing
SMTP_USE_SSL=True
SMTP_USE_TLS=False
SMTP_TIMEOUT_SECONDS=20

# Behavior
GUIDE_IDLE_TIMEOUT=600
GUIDE_QUIET_TIMEOUT=900
GUIDE_SHORT_ANSWER_THRESHOLD=20
GRAPH_CACHE_ENABLED=True
GRAPH_CACHE_TTL_MINUTES=15
GRAPH_CACHE_MAX_SIZE=20
GRAPH_CACHE_CLEANUP_INTERVAL_MINUTES=5
FULL_CONTEXT_ENABLED=True
CONTEXT_COMPRESS_AFTER_ROUNDS=5
CONTEXT_KEEP_LATEST_MESSAGES=3
CONTEXT_MAX_TOKEN_BUDGET=8000

# Frontend API and startup
NEXT_PUBLIC_API_URL=
FRONTEND_MODE=production
