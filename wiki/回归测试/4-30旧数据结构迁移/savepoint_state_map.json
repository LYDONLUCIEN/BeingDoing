{
  "schema_version": 1,
  "description": "存档点 STATE_CODE 与后端可观测节点、主要 API 的映射（供造数脚本与回归文档引用）。",
  "phase_ids": ["values", "strengths", "interests", "purpose", "rumination"],
  "api_index": {
    "POST /api/v1/simple-auth/activate": "激活码校验与首次归属绑定",
    "POST /api/v1/simple-chat/init": "阶段首轮引导（含 rumination 入口）",
    "POST /api/v1/simple-chat/message/stream": "主对话流式回复（含 STATE_JSON / pending 分支）",
    "GET /api/v1/simple-chat/history": "读取当前 phase+thread 历史与 metadata",
    "POST /api/v1/simple-chat/thread/complete": "阶段提交：选定 thread、写 prior、标记完成",
    "POST /api/v1/simple-chat/thread/reopen": "阶段重开继续聊",
    "POST /api/v1/simple-chat/thread/delete": "删除线程",
    "GET /api/v1/simple-chat/threads": "线程列表",
    "GET /api/v1/simple-chat/rumination-progress": "rumination 进度读取",
    "POST /api/v1/simple-chat/rumination-progress": "rumination 进度写入",
    "GET /api/v1/simple-chat/rumination-step-opening": "子步固定/合成开场",
    "POST /api/v1/simple-chat/rumination-table-submit": "表格提交与闸门/短链",
    "POST /api/v1/simple-chat/rumination-neg-resolve": "否定闸门后续决策",
    "POST /api/v1/simple-chat/rumination-regenerate-hypotheses": "假设行重生成"
  },
  "observable_fields": {
    "report_record_json": "data/simple/reports/{report_id}/record.json → steps.*.locked | selected_session_id | session_ids",
    "conversation_metadata": "{phase}__{thread_id}.json → metadata.conclusion_state | thread_completed | conclusion_draft",
    "rumination_progress_json": "rumination_progress.json → main_section | filter_step | pending_table_submit | rumination_neg_state | filter_early_terminated",
    "sse_stream": "chunk 不含泄漏的 [STATE_JSON]；末包 done=true"
  },
  "states": [
    {
      "state_code": "0-1",
      "title": "未激活",
      "phase": null,
      "backend_node": "activation_unclaimed",
      "primary_apis": ["POST /api/v1/simple-auth/activate"],
      "assertions_hint": ["无 report 或首次 ensure_report 创建"],
      "llm_risk": "low"
    },
    {
      "state_code": "0-2",
      "title": "首次激活",
      "phase": "values",
      "backend_node": "post_activate_first_entry",
      "primary_apis": ["POST /api/v1/simple-auth/activate", "POST /api/v1/simple-chat/init"],
      "assertions_hint": ["可进入 values；record 存在"],
      "llm_risk": "medium"
    },
    {
      "state_code": "1-1",
      "title": "values init 引导完毕",
      "phase": "values",
      "backend_node": "phase_init_done",
      "primary_apis": ["POST /api/v1/simple-chat/init", "GET /api/v1/simple-chat/history"],
      "assertions_hint": ["history 有首轮 assistant；metadata 初始"],
      "llm_risk": "medium"
    },
    {
      "state_code": "1-2",
      "title": "values 正常交流",
      "phase": "values",
      "backend_node": "dialogue_active",
      "primary_apis": ["POST /api/v1/simple-chat/message/stream"],
      "assertions_hint": ["STATE_JSON 合法或 continue；无泄漏"],
      "llm_risk": "high"
    },
    {
      "state_code": "1-3-a",
      "title": "values 出卡",
      "phase": "values",
      "backend_node": "conclusion_pending_ready",
      "primary_apis": ["POST /api/v1/simple-chat/message/stream"],
      "assertions_hint": ["metadata.conclusion_state=pending", "conclusion_draft 非空"],
      "llm_risk": "high"
    },
    {
      "state_code": "1-3-b",
      "title": "values 出卡否认",
      "phase": "values",
      "backend_node": "pending_decision_rejected",
      "primary_apis": ["POST /api/v1/simple-chat/message/stream"],
      "assertions_hint": ["pending 判定 rejected；回到对话态"],
      "llm_risk": "high"
    },
    {
      "state_code": "1-3-c",
      "title": "values 出卡否认后问答",
      "phase": "values",
      "backend_node": "dialogue_after_reject",
      "primary_apis": ["POST /api/v1/simple-chat/message/stream"],
      "assertions_hint": ["可再次收敛 pending"],
      "llm_risk": "high"
    },
    {
      "state_code": "1-3-d",
      "title": "values 二次出卡",
