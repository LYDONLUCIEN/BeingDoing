  "cross_cutting": [
    {
      "id": "auth_owner_mismatch",
      "title": "激活码归属非本人",
      "primary_apis": ["POST /api/v1/simple-auth/activate"],
      "assertions_hint": ["403 该激活码已被其他用户使用"],
      "llm_risk": "none"
    },
    {
      "id": "activation_expired_revoked",
